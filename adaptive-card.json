{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "bleed": true,
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "Image",
                  "url": "${iconUrl}",
                  "width": "40px",
                  "height": "40px"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "LIMINAL",
                  "weight": "Bolder",
                  "size": "Medium",
                  "color": "Warning"
                },
                {
                  "type": "TextBlock",
                  "text": "DETECTION SYSTEM",
                  "size": "Small",
                  "color": "Accent",
                  "spacing": "None"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "LAST SCAN",
                  "size": "Small",
                  "color": "Accent",
                  "weight": "Bolder"
                },
                {
                  "type": "TextBlock",
                  "text": "${lastScanProbability}",
                  "size": "ExtraLarge",
                  "weight": "Bolder",
                  "color": "${lastScanColor}",
                  "spacing": "None"
                },
                {
                  "type": "TextBlock",
                  "text": "${lastScanLabel}",
                  "size": "Small",
                  "color": "Accent",
                  "spacing": "None"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "SCANS",
                  "size": "Small",
                  "color": "Accent",
                  "weight": "Bolder"
                },
                {
                  "type": "TextBlock",
                  "text": "${totalScans}",
                  "size": "ExtraLarge",
                  "weight": "Bolder",
                  "color": "Warning",
                  "spacing": "None"
                }
              ]
            }
          ]
        },
        {
          "type": "TextBlock",
          "text": "${lastScanTime}",
          "size": "Small",
          "color": "Accent",
          "spacing": "Small"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "📷  SCAN NOW",
      "url": "${appUrl}?action=scan"
    },
    {
      "type": "Action.OpenUrl",
      "title": "📋  CHECKLIST",
      "url": "${appUrl}?action=manual"
    }
  ]
}
